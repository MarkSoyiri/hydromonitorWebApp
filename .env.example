# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=hydromonitor-v2.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://hydromonitor-v2-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=hydromonitor-v2
VITE_FIREBASE_STORAGE_BUCKET=hydromonitor-v2.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API
VITE_API_URL=http://localhost:3000

# Production Backend (uncomment for production)
# VITE_API_URL=https://your-backend-url.vercel.app

# Emulators (set to true for local development)
VITE_USE_EMULATORS=false
